{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["bun", "bun-types", "./tampermonkey-module.d.ts"],
    "allowImportingTsExtensions": true,
    "rootDir": ".",
    "paths": {
      "@app/*": ["./src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "lib": ["dom", "dom.iterable", "ESNext"],
    "removeComments": true,
    "experimentalDecorators": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
