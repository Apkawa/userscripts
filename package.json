{
  "author": "Apkawa",
  "homepage": "https://github.com/Apkawa/userscripts",
  "repository": "https://github.com/Apkawa/userscripts",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Apkawa/userscripts/issues"
  },
  "readme": "README.md",
  "devDependencies": {
    "@babel/plugin-proposal-pipeline-operator": "^7.15.0",
    "@biomejs/biome": "^2.4.12",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.12",
    "@types/eslint": "^9.6.1",
    "@types/eslint-plugin-prettier": "^3.1.0",
    "@types/node": "^25.6.0",
    "@types/prettier": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "bun-types": "^1.3.12",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-google": "^0.14.0",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-formatter-visualstudio": "^9.0.1",
    "eslint-formatter-vso": "^0.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-userscripts": "0.5.6",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "process": "^0.11.10",
    "raw-loader": "^4.0.2",
    "ts-jest": "^29.0.3",
    "ts-loader": "^9.2.6",
    "ts-node": "^10.2.1",
    "tsconfig-paths": "^4.2.0",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "typesync": "^0.14.3"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "build": "bun build/build-userscripts.ts",
    "build:watch": "BUN_OPTIONS='--watch' WATCH=1 npm run build",
    "prepare": "husky",
    "synctypes": "typesync && npm i",
    "format": "biome format --write src/ build/",
    "format:check": "biome check src/ --write",
    "test": "bun test",
    "type": "tsc --noEmit -p .",
    "lint": "eslint src/ --ext js,ts,tsx --max-warnings=0 --fix --format unix --color",
    "check": "bun run test && bun lint && bun format:check",
    "pre-commit": "npm run format && npm run build && git add -A dist/"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "packageManager": "bun@1.1.20",
  "husky": {
    "hooks": {
      "pre-commit": "npm run pre-commit"
    }
  },
  "browserslist": [
    "last 2 years",
    "> 1%",
    "not dead"
  ],
  "babel": {
    "plugins": [
      [
        "@babel/plugin-proposal-pipeline-operator",
        {
          "proposal": "minimal"
        }
      ]
    ]
  },
  "prettier": {
    "bracketSpacing": false,
    "tabWidth": 2,
    "useTabs": false,
    "trailingComma": "all",
    "singleQuote": true,
    "printWidth": 100
  }
}
